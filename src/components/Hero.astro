---
---

<section id="hero" aria-label="Hero">
  <!-- Background gradient overlay -->
  <div class="hero__bg"></div>
  <div class="hero__pattern"></div>

  <div class="hero__grid">
    <div class="hero__left">
      <span class="section__label section__label--light">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        Palayapalayam, Erode
      </span>
      <h1 class="hero__heading">
        DentiQ <em>Superspeciality</em> Laser Dental Hospital
      </h1>
      <p class="hero__sub">
        We are an expert team of dental superspecialists to get you out of your dental ailments confidently and comfortably. We make sure all our patients leave with a smile of relief and happiness.
      </p>
      <div class="hero__actions">
        <a href="/contact" class="btn btn--primary" data-magnetic data-cursor-hover>
          Book Appointment
        </a>
        <a href="/contact" class="btn btn--free-consult" data-magnetic data-cursor-hover>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:8px;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          Free Consultation
        </a>
      </div>

      <!-- Stat row -->
      <div class="hero__stats">
        <div class="hero__stat">
          <span class="hero__stat-num">20+</span>
          <span class="hero__stat-label">Years Experience</span>
        </div>
        <div class="hero__stat-divider"></div>
        <div class="hero__stat">
          <span class="hero__stat-num">3000+</span>
          <span class="hero__stat-label">Happy Patients</span>
        </div>
        <div class="hero__stat-divider"></div>
        <div class="hero__stat">
          <span class="hero__stat-num">4.9 <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="display:inline-block; vertical-align:middle; margin-top:-4px;"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg></span>
          <span class="hero__stat-label">Google Rating</span>
        </div>
        <div class="hero__stat-divider"></div>
        <div class="hero__stat">
          <span class="hero__stat-num">99%</span>
          <span class="hero__stat-label">Satisfaction</span>
        </div>
      </div>
    </div>

    <!-- Right: floating info card -->
    <div class="hero__right" aria-hidden="true">
      <div class="hero__card">
        <div class="hero__card-icon">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/><path d="M8 14h.01M12 14h.01M16 14h.01M8 18h.01M12 18h.01"/></svg>
        </div>
        <h3 class="hero__card-title">Book a Consultation</h3>
        <p class="hero__card-text">Speak with India's top orofacial pain specialist today.</p>
        <div class="hero__card-hours">
          <div class="hero__card-hour-row">
            <span>Mon – Sat</span><span>9:00 AM – 8:00 PM</span>
          </div>
          <div class="hero__card-hour-row">
            <span>Sunday</span><span>10:00 AM – 8:00 PM</span>
          </div>
        </div>
        <a href="tel:+918489488999" class="btn btn--primary hero__card-btn" data-cursor-hover>
          +91 84894 88999
        </a>
      </div>

      <!-- Floating badges -->
      <div class="hero__badge hero__badge--1">
        <span class="hero__badge-icon">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        </span>
        <span>TMJ Specialist</span>
      </div>
      <div class="hero__badge hero__badge--2">
        <span class="hero__badge-icon">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        </span>
        <span>Sleep Dentistry</span>
      </div>
      <div class="hero__badge hero__badge--3">
        <span class="hero__badge-icon">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        </span>
        <span>Migraine Relief</span>
      </div>
    </div>
  </div>

  <!-- Scroll hint -->
  <div class="hero__scroll-hint" aria-label="Scroll down">
    <span class="hero__scroll-line"><span></span></span>
  </div>
</section>

<style>
  #hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    background: linear-gradient(135deg, var(--clr-navy) 0%, #5b543c 55%, #6b6445 100%);
    padding: 7rem var(--gutter) var(--space-20);
    overflow: hidden;
  }

  /* Background texture */
  .hero__bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 70% at 75% 50%, rgba(206,196,167,0.10) 0%, transparent 65%),
      radial-gradient(ellipse 40% 40% at 10% 80%, rgba(107,100,69,0.5) 0%, transparent 60%);
    pointer-events: none;
  }
  .hero__pattern {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(255,255,255,0.04) 1px, transparent 1px);
    background-size: 32px 32px;
    pointer-events: none;
  }

  .hero__grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: var(--space-16);
    align-items: center;
    max-width: var(--max-width);
    margin: 0 auto;
    width: 100%;
  }

  /* Left */
  .hero__heading {
    font-family: var(--font-heading);
    font-size: var(--text-hero);
    font-weight: 600;
    line-height: 1.08;
    color: var(--clr-white);
    margin-bottom: var(--space-6);
    letter-spacing: -0.01em;
    opacity: 0;
  }
  .hero__heading em {
    font-style: italic;
    color: var(--clr-gold);
  }

  .hero__sub {
    font-size: var(--text-lg);
    font-weight: 300;
    line-height: 1.8;
    color: rgba(255,255,255,0.78);
    margin-bottom: var(--space-10);
    max-width: 50ch;
    opacity: 0;
  }

  .hero__actions {
    display: flex;
    gap: var(--space-4);
    margin-bottom: var(--space-12);
    opacity: 0;
  }
  .btn--free-consult {
    background: transparent;
    border: 1px solid var(--clr-gold);
    color: var(--clr-gold);
    padding: 12px 28px;
    border-radius: var(--radius-pill);
    font-weight: 600;
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    transition: all 0.3s ease;
  }
  .btn--free-consult:hover {
    background: var(--clr-gold);
    color: var(--clr-white);
    box-shadow: var(--shadow-gold);
  }

  @media (max-width: 500px) {
    .hero__actions {
      flex-direction: column;
      width: 100%;
    }
    .hero__actions .btn {
      width: 100%;
      text-align: center;
      justify-content: center;
    }
  }

  /* Stats row */
  .hero__stats {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    flex-wrap: wrap;
    opacity: 0;
    padding: var(--space-6) var(--space-8);
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: var(--radius-lg);
    backdrop-filter: blur(10px);
  }
  .hero__stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    flex: 1;
    min-width: 80px;
  }
  .hero__stat-num {
    font-family: var(--font-body);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--clr-gold);
    line-height: 1;
  }
  .hero__stat-label {
    font-size: 0.68rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.6);
    text-align: center;
  }
  .hero__stat-divider {
    width: 1px;
    height: 36px;
    background: rgba(255,255,255,0.15);
    flex-shrink: 0;
  }

  /* Right – card */
  .hero__right {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 460px;
    opacity: 0;
  }

  .hero__card {
    background: var(--clr-white);
    border-radius: var(--radius-xl);
    padding: var(--space-10) var(--space-10);
    box-shadow: 0 24px 64px rgba(0,0,0,0.30);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    width: 100%;
    max-width: 340px;
    animation: float-card 5s ease-in-out infinite;
  }

  @keyframes float-card {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-10px); }
  }

  .hero__card-icon {
    font-size: 2rem;
    width: 56px;
    height: 56px;
    background: var(--clr-gold-pale);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero__card-title {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--clr-navy);
    line-height: 1.2;
  }
  .hero__card-text {
    font-size: var(--text-sm);
    color: var(--clr-text-mid);
    line-height: 1.65;
  }
  .hero__card-hours {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-4);
    background: var(--clr-off-white);
    border-radius: var(--radius-md);
    margin: var(--space-2) 0;
  }
  .hero__card-hour-row {
    display: flex;
    justify-content: space-between;
    font-size: var(--text-xs);
    color: var(--clr-text-body);
    font-weight: 400;
  }
  .hero__card-hour-row span:last-child { font-weight: 600; color: var(--clr-navy); }
  .hero__card-btn { width: 100%; font-size: var(--text-xs) !important; padding: 12px 20px !important; }

  /* Floating badges */
  .hero__badge {
    position: absolute;
    display: flex;
    align-items: center;
    gap: var(--space-2);
    background: var(--clr-navy);
    color: var(--clr-white);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.06em;
    padding: 8px 16px;
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-md);
    border: 1px solid rgba(206,196,167,0.3);
    white-space: nowrap;
  }
  .hero__badge-icon {
    color: var(--clr-gold);
    font-size: 0.8rem;
  }
  .hero__badge--1 { top: 12%;  left: -5%;  animation: badge-float 4s ease-in-out infinite; }
  .hero__badge--2 { top: 45%;  right: -8%; animation: badge-float 4s ease-in-out 1.3s infinite; }
  .hero__badge--3 { bottom: 8%; left: 5%;  animation: badge-float 4s ease-in-out 2.1s infinite; }

  @keyframes badge-float {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-7px); }
  }

  /* Scroll hint */
  .hero__scroll-hint {
    position: absolute;
    bottom: var(--space-8);
    left: 50%;
    transform: translateX(-50%);
    opacity: 0;
  }
  .hero__scroll-line {
    width: 1px;
    height: 52px;
    overflow: hidden;
    display: block;
  }
  .hero__scroll-line span {
    display: block;
    width: 1px;
    height: 100%;
    background: rgba(206,196,167,0.7);
    animation: scroll-drop 2s ease-in-out infinite;
  }
  @keyframes scroll-drop {
    0%   { transform: translateY(-100%); }
    100% { transform: translateY(200%); }
  }

  /* Responsive */
  @media (max-width: 1024px) {
    #hero { align-items: flex-start; padding-top: 8.5rem; min-height: auto; padding-bottom: 6rem; }
    .hero__grid { grid-template-columns: 1fr; gap: var(--space-10); }
    .hero__right { display: none; }
    .hero__heading { font-size: 2.8rem; line-height: 1.1; }
    .hero__sub { font-size: 1.1rem; }
  }
  @media (max-width: 600px) {
    .hero__stats { 
      gap: var(--space-4); 
      padding: var(--space-4); 
      display: grid;
      grid-template-columns: 1fr 1fr;
      text-align: center;
    }
    .hero__stat-divider { display: none; }
    .hero__heading { font-size: 1.8rem; letter-spacing: -0.02em; }
    .hero__sub { font-size: 0.95rem; line-height: 1.7; margin-bottom: var(--space-8); }
    .hero__stat-num { font-size: 1.3rem; }
    .hero__stat-label { font-size: 0.6rem; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  window.addEventListener('loader:complete', () => {
    const tl = gsap.timeline({ defaults: { ease: 'power4.out' } });

    tl
      .to('.section__label', { opacity: 1, y: 0, duration: 0.8 })
      .to('.hero__heading', { opacity: 1, y: 0, duration: 1 }, '-=0.4')
      .to('.hero__sub',     { opacity: 1, duration: 0.8 }, '-=0.6')
      .to('.hero__actions', { opacity: 1, duration: 0.7 }, '-=0.5')
      .to('.hero__stats',   { opacity: 1, y: 0, duration: 0.7 }, '-=0.4')
      .to('.hero__right',   { opacity: 1, x: 0, duration: 0.9 }, '-=0.5')
      .to('.hero__scroll-hint', { opacity: 1, duration: 0.5 }, '-=0.2');
  });

  // Initial state
  gsap.set(['.hero__heading','.hero__stats'], { y: 40 });
  gsap.set('.hero__right', { x: 60 });

  // Parallax on scroll
  ScrollTrigger.create({
    trigger: '#hero',
    start: 'top top',
    end: 'bottom top',
    onUpdate(self) {
      gsap.set('.hero__bg', { y: self.progress * 80 });
    },
  });

  // Magnetic buttons
  document.querySelectorAll('[data-magnetic]').forEach((btn) => {
    const el = btn as HTMLElement;
    el.addEventListener('mousemove', (e) => {
      const rect = el.getBoundingClientRect();
      const dx = (e.clientX - (rect.left + rect.width  / 2)) * 0.25;
      const dy = (e.clientY - (rect.top  + rect.height / 2)) * 0.25;
      gsap.to(el, { x: dx, y: dy, duration: 0.4, ease: 'power2.out' });
    });
    el.addEventListener('mouseleave', () => {
      gsap.to(el, { x: 0, y: 0, duration: 0.7, ease: 'elastic.out(1, 0.4)' });
    });
  });
</script>
