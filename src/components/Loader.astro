---
---

<div id="loader" aria-hidden="true">
  <div class="loader__curtain loader__curtain--top"></div>
  <div class="loader__curtain loader__curtain--bottom"></div>
  <div class="loader__content">
    <div class="loader__logo">
      <span class="loader__logo-main">DentiQ</span>
      <span class="loader__logo-sub">Laser Dental Hospital</span>
    </div>
    <span class="loader__tagline">Erode Hospital — Superspeciality Care</span>
    <div class="loader__bar-wrap">
      <div class="loader__bar-fill"></div>
    </div>
  </div>
</div>

<style>
  #loader {
    position: fixed;
    inset: 0;
    z-index: 9000;
    pointer-events: all;
    overflow: hidden;
  }

  .loader__curtain {
    position: absolute;
    left: 0;
    right: 0;
    height: 50%;
    background: var(--clr-navy);
  }
  .loader__curtain--top    { top: 0; }
  .loader__curtain--bottom { bottom: 0; }

  .loader__content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    z-index: 1;
  }

  .loader__logo {
    display: flex;
    flex-direction: column;
    align-items: center;
    overflow: hidden;
  }

  .loader__logo-main {
    display: block;
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 6vw, 5.5rem);
    font-weight: 600;
    color: var(--clr-white);
    letter-spacing: 0.02em;
    transform: translateY(105%);
    line-height: 1.1;
  }
  .loader__logo-sub {
    display: block;
    font-family: var(--font-body);
    font-size: clamp(0.75rem, 1.8vw, 1rem);
    font-weight: 400;
    color: var(--clr-gold);
    letter-spacing: 0.32em;
    text-transform: uppercase;
    transform: translateY(105%);
    margin-top: var(--space-2);
  }

  .loader__tagline {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 300;
    color: rgba(255,255,255,0.5);
    letter-spacing: 0.24em;
    text-transform: uppercase;
    opacity: 0;
    margin-top: var(--space-2);
  }

  .loader__bar-wrap {
    width: 100px;
    height: 2px;
    background: rgba(255,255,255,0.12);
    border-radius: 2px;
    overflow: hidden;
    margin-top: var(--space-4);
  }
  .loader__bar-fill {
    height: 100%;
    width: 0;
    background: linear-gradient(90deg, var(--clr-gold), var(--clr-gold-light));
    border-radius: 2px;
    transform-origin: left;
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const tl = gsap.timeline({ delay: 0.1 });

  tl
    .to(['.loader__logo-main', '.loader__logo-sub'], {
      y: 0,
      duration: 1.0,
      stagger: 0.1,
      ease: 'power4.out',
    })
    .to('.loader__tagline', { opacity: 1, duration: 0.6, ease: 'power2.out' }, '-=0.4')
    .to('.loader__bar-fill', { width: '100%', duration: 0.9, ease: 'power2.inOut' }, '-=0.3')
    .to({}, { duration: 0.5 })
    .to('.loader__content', { opacity: 0, duration: 0.3, ease: 'power2.in' })
    .to('.loader__curtain--top', {
      yPercent: -100,
      duration: 1.0,
      ease: 'power4.inOut',
    }, '-=0.05')
    .to('.loader__curtain--bottom', {
      yPercent: 100,
      duration: 1.0,
      ease: 'power4.inOut',
    }, '<')
    .call(() => {
      removeLoader();
    });

  function removeLoader() {
    const loader = document.getElementById('loader');
    if (loader && loader.style.display !== 'none') {
      loader.style.display = 'none';
      document.body.classList.remove('is-loading');
      ScrollTrigger.refresh();
      window.dispatchEvent(new CustomEvent('loader:complete'));
    }
  }

  // Safety timeout
  setTimeout(removeLoader, 3500);
</script>
