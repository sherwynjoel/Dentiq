<section class="quick-contact">
  <div class="quick-contact__inner">
    <div class="qc-card">
      <div class="qc-card__icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l2.28-2.28a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      </div>
      <div class="qc-card__content">
        <h4 class="qc-card__title">Call Us Today</h4>
        <p class="qc-card__val">+91 84894 88999</p>
      </div>
    </div>
    <div class="qc-card">
      <div class="qc-card__icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
      </div>
      <div class="qc-card__content">
        <h4 class="qc-card__title">Email Us</h4>
        <p class="qc-card__val">info@dentiqsuperspeciality.com</p>
      </div>
    </div>
    <div class="qc-card">
      <div class="qc-card__icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      </div>
      <div class="qc-card__content">
        <h4 class="qc-card__title">Opening Hours</h4>
        <p class="qc-card__val">Mon – Sat: 9AM – 8PM</p>
      </div>
    </div>
  </div>
</section>

<style>
  .quick-contact {
    position: relative;
    z-index: 10;
    margin-top: -60px;
    padding: 0 var(--gutter);
    background: var(--clr-navy);
  }

  .quick-contact__inner {
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
  }

  .qc-card {
    background: var(--clr-white);
    padding: var(--space-8) var(--space-5);
    border-radius: var(--radius-lg);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    justify-content: center;
    gap: var(--space-4);
    box-shadow: var(--shadow-lg);
    transition: transform 0.3s var(--ease-out-expo);
  }
  .qc-card:hover {
    transform: translateY(-5px);
  }

  .qc-card__icon {
    width: 60px;
    height: 60px;
    background: var(--clr-gold-pale);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .qc-card__title {
    font-size: 0.70rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--clr-gold);
    margin-bottom: 2px;
  }

  .qc-card__val {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--clr-navy);
    word-break: break-word;
  }

  @media (max-width: 900px) {
    .quick-contact { margin-top: -30px; }
    .quick-contact__inner { grid-template-columns: 1fr; }
  }
  @media (max-width: 600px) {
    .qc-card { 
      padding: var(--space-4) var(--space-5); 
      flex-direction: row; 
      text-align: left; 
      justify-content: flex-start;
      gap: var(--space-5);
    }
    .qc-card__icon { width: 44px; height: 44px; font-size: 1.1rem; }
    .qc-card__val { font-size: 0.85rem; }
  }
</style>
