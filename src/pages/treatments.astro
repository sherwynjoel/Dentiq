---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Cursor from '../components/Cursor.astro';
import { treatmentsData } from '../data/treatmentsData.js';
---

<BaseLayout title="Treatments & Specialities | DentiQ Erode" description="Explore our dental specialities at DentiQ Erode. Find dedicated care for your smile.">
  <Cursor />
  <Nav />

  <section class="treatments-hero">
    <div class="container">
      <span class="section__label section__label--light">Comprehensive Care</span>
      <h1 class="hero__heading">Our <em>Specialities</em></h1>
      <p class="hero__sub">Advanced dental treatments powered by Erode's expert team.</p>
    </div>
  </section>

  <section class="treatments-directory">
    <div class="container">
      <div class="t-search-container">
        <input type="text" id="t-search" placeholder="Search treatments..." class="t-search-input" />
      </div>

      <div class="t-grid" id="t-grid">
        {treatmentsData.map((cat) => (
          <div class="t-card" data-name={cat.name.toLowerCase()}>
            <div class="t-card__icon" set:html={cat.icon}></div>
            <h3 class="t-card__title">{cat.name}</h3>
            {cat.catchy && <p class="t-card__catchy">{cat.catchy}</p>}
            <a href={`/treatments/${cat.id}`} class="t-card__link">View Details &rarr;</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .container { max-width: var(--max-width); margin: 0 auto; padding: 0 var(--gutter); }

  .treatments-hero {
    background: var(--clr-navy);
    padding: 10rem 0 6rem;
    text-align: center;
    color: var(--clr-white);
  }
  .hero__heading { font-family: var(--font-heading); font-size: 3.5rem; margin-bottom: 1.5rem; }
  .hero__heading em { font-style: italic; color: var(--clr-gold); }
  .hero__sub { font-size: var(--text-lg); color: rgba(255,255,255,0.8); font-weight: 300; }

  .treatments-directory {
    padding: 6rem 0;
    background: var(--clr-white);
  }

  .t-search-container {
    max-width: 600px;
    margin: 0 auto 4rem;
  }
  .t-search-input {
    width: 100%;
    padding: 16px 24px;
    border-radius: var(--radius-pill);
    border: 2px solid var(--clr-light-gray);
    background: var(--clr-off-white);
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--clr-text-dark);
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    text-align: center;
  }
  .t-search-input:focus {
    border-color: var(--clr-navy);
    box-shadow: 0 0 0 4px rgba(78, 72, 50, 0.1);
    background: var(--clr-white);
  }

  .t-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2.5rem;
  }

  .t-card {
    background: var(--clr-off-white);
    padding: 2.5rem;
    border-radius: var(--radius-xl);
    border: 1px solid var(--clr-light-gray);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .t-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-md);
    border-color: var(--clr-gold);
  }

  .t-card__icon {
    width: 64px;
    height: 64px;
    background: var(--clr-white);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--clr-gold);
    margin-bottom: 1.5rem;
    box-shadow: var(--shadow-sm);
  }
  .t-card__title { font-family: var(--font-heading); font-size: 1.4rem; color: var(--clr-navy); margin-bottom: 0.8rem; }
  .t-card__catchy { font-size: 0.85rem; color: var(--clr-text-mid); line-height: 1.5; margin-bottom: 1.5rem; font-weight: 300; }
  .t-card__link {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--clr-navy);
    text-decoration: none;
    margin-top: auto;
    transition: color 0.2s ease;
  }
  .t-card__link:hover {
    color: var(--clr-gold);
  }
</style>

<script>
  const searchInput = document.getElementById('t-search') as HTMLInputElement;
  const cards = document.querySelectorAll('.t-card') as NodeListOf<HTMLElement>;

  searchInput?.addEventListener('input', (e) => {
    const query = (e.target as HTMLInputElement).value.toLowerCase();
    cards.forEach(card => {
      const name = card.dataset.name || '';
      if (name.includes(query)) {
        card.style.display = 'flex';
      } else {
        card.style.display = 'none';
      }
    });
  });
</script>
